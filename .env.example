# URL base da API em produção
# (já definido em .env.production para deploy Vercel)
VITE_API_BASE_URL=https://api.lanzalocacoes.vercel.app

# API key (quando LANZA_API_KEY está definida no servidor)
# VITE_API_KEY=

# Em dev local, deixe VITE_API_BASE_URL vazio para usar o proxy do Vite
# VITE_API_PROXY_TARGET=http://127.0.0.1:3100
